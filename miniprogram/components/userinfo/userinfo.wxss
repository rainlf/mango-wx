.userinfo-card {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  gap: 20rpx;
  margin: 12rpx 20rpx 0;
  border-radius: 18rpx;
  background-color: rgba(10, 18, 30, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  backdrop-filter: blur(10rpx);
}

.userinfo-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.userinfo-avatar-placeholder {
  background-color: rgba(255, 255, 255, 0.12);
}

.userinfo-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.userinfo-name {
  color: rgba(255, 255, 255, 0.92);
  font-size: 30rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.35);
}

.userinfo-points {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.25);
}

.userinfo-settings {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.5;
}
