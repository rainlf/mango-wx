.userinfo-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  gap: 20rpx;
}

.userinfo-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.userinfo-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.userinfo-name {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.userinfo-points {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.userinfo-settings {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.5;
}
