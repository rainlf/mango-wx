/* 用户信息组件样式 */
.userinfo-container {
  padding: 16rpx 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 252, 255, 0.98) 100%);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.1);
  margin: 20rpx 20rpx 10rpx 20rpx;
  border: 1rpx solid rgba(126, 159, 209, 0.16);
  overflow: hidden;
}

.settings-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #e4efff 100%);
  border: 1rpx solid rgba(74, 144, 226, 0.14);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.profile-card {
  padding: 12rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f6faff 0%, #edf4ff 58%, #fff8eb 100%);
  border: 1rpx solid rgba(101, 149, 224, 0.12);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(228, 239, 255, 0.95) 100%);
  box-shadow: 0 6rpx 18rpx rgba(74, 144, 226, 0.1);
  flex-shrink: 0;
  box-sizing: border-box;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.info-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 14rpx;
  padding-top: 2rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 80rpx;
}

.identity-block {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  min-height: 80rpx;
}

.username {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2f45;
  line-height: 1.1;
  letter-spacing: 0.4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.points-box {
  width: 248rpx;
  max-width: 42%;
  margin-left: 20rpx;
  height: 80rpx;
  padding: 0 21rpx;
  border-radius: 13rpx;
  background: linear-gradient(135deg, rgba(255, 251, 242, 0.98) 0%, rgba(255, 240, 204, 0.98) 100%);
  border: 1rpx solid rgba(255, 183, 77, 0.24);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  box-shadow:
    0 4rpx 10rpx rgba(255, 183, 77, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.58);
}

.points-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.coin-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd66b 0%, #ffb300 100%);
  border: 1rpx solid rgba(214, 144, 0, 0.35);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 248, 220, 0.8),
    0 2rpx 4rpx rgba(255, 183, 77, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.coin-icon-inner {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 241, 196, 0.75);
}

.points-label {
  font-size: 25rpx;
  color: #7d6546;
  line-height: 1.15;
  font-weight: 500;
  opacity: 0.92;
  white-space: nowrap;
}

.points {
  font-size: 44rpx;
  color: #ff9900;
  font-weight: 700;
  line-height: 1;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.4);
}

.stats-panel {
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  margin-top: 2rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  min-height: 92rpx;
  padding: 14rpx 10rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 6rpx;
  box-sizing: border-box;
  border-radius: 13rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f1f6fd 100%);
  border: 1rpx solid rgba(93, 131, 191, 0.14);
  box-shadow: 0 3rpx 8rpx rgba(86, 115, 156, 0.05);
}

.stats-panel .stat-item:nth-child(1) {
  background: linear-gradient(180deg, #f4fbf9 0%, #e3f5ef 100%);
  border-color: rgba(82, 166, 145, 0.24);
  box-shadow: 0 4rpx 10rpx rgba(82, 166, 145, 0.08);
}

.stats-panel .stat-item:nth-child(1) .stat-label {
  color: #5f9286;
}

.stats-panel .stat-item:nth-child(1) .stat-value {
  color: #2b7b67;
}

.stats-panel .stat-item:nth-child(2) {
  background: linear-gradient(180deg, #f7f5ff 0%, #ece8ff 100%);
  border-color: rgba(132, 118, 230, 0.24);
  box-shadow: 0 4rpx 10rpx rgba(132, 118, 230, 0.08);
}

.stats-panel .stat-item:nth-child(2) .stat-label {
  color: #7d72be;
}

.stats-panel .stat-item:nth-child(2) .stat-value {
  color: #5a4db0;
}

.stat-item-highlight {
  position: relative;
  background: linear-gradient(180deg, #fff8ec 0%, #ffe6b8 100%);
  border-color: rgba(255, 172, 47, 0.3);
  box-shadow: 0 5rpx 12rpx rgba(255, 172, 47, 0.12);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #25364e;
  line-height: 1.1;
  text-align: center;
  flex-shrink: 0;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

.stat-value-highlight {
  color: #ff9900;
}

.stat-label {
  font-size: 24rpx;
  color: #7f8fa5;
  line-height: 1.2;
  font-weight: 500;
  white-space: nowrap;
  text-align: center;
}

.gear-icon {
  width: 28rpx;
  height: 28rpx;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.settings-btn:active .gear-icon {
  transform: rotate(24deg);
  opacity: 0.96;
}
