/* 用户信息组件样式 */
.userinfo-container {
  display: flex;
  align-items: flex-start;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin: 20rpx 20rpx 10rpx 20rpx;
  position: relative;
  overflow: hidden;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-right: 32rpx;
  border: 4rpx solid #f5f5f5;
  flex-shrink: 0;
}

.info-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-right: 72rpx;
}

.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
  max-width: 220rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.points-box {
  display: flex;
  align-items: center;
  background: #fff7e6;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  flex-shrink: 0;
}

.points-label {
  font-size: 26rpx;
  color: #666;
}

.points {
  font-size: 32rpx;
  color: #ff9900;
  font-weight: bold;
  margin-left: 12rpx;
}

.stats-grid {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  min-width: 0;
  background: linear-gradient(180deg, #fafbfd 0%, #f4f7fb 100%);
  border-radius: 18rpx;
  padding: 18rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: inset 0 0 0 1rpx rgba(74, 144, 226, 0.08);
}

.stat-card-highlight {
  background: linear-gradient(180deg, #fff8e8 0%, #fff2cf 100%);
  box-shadow: inset 0 0 0 1rpx rgba(255, 153, 0, 0.16);
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f3a4a;
  line-height: 1.2;
}

.stat-value-highlight {
  color: #ff9900;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8a94a6;
  line-height: 1.2;
}

/* components/userinfo/userinfo.wxss */
.settings-btn {
  position: absolute;
  top: 24rpx;
  right: 16rpx;
  padding: 16rpx;
  opacity: 0.8;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.gear-icon {
  width: 48rpx;
  height: 48rpx;
  transition: transform 0.3s ease;
}

.settings-btn:active .gear-icon {
  transform: rotate(30deg);
  opacity: 1;
}
