/* 用户信息组件样式 */
.userinfo-container {
  padding: 16rpx 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 252, 255, 0.98) 100%);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.1);
  margin: 20rpx 20rpx 10rpx 20rpx;
  border: 1rpx solid rgba(126, 159, 209, 0.16);
  overflow: hidden;
}

.settings-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #e4efff 100%);
  border: 1rpx solid rgba(74, 144, 226, 0.14);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.profile-card {
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f6faff 0%, #edf4ff 58%, #fff8eb 100%);
  border: 1rpx solid rgba(101, 149, 224, 0.12);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar-wrap {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(228, 239, 255, 0.95) 100%);
  box-shadow: 0 6rpx 18rpx rgba(74, 144, 226, 0.1);
  flex-shrink: 0;
  box-sizing: border-box;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.info-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 56rpx;
}

.identity-block {
  flex: 1;
  min-width: 0;
  padding: 4rpx 0;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.username {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2f45;
  line-height: 1.2;
  letter-spacing: 0.4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.points-box {
  min-width: 132rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, rgba(255, 250, 240, 0.96) 0%, rgba(255, 243, 214, 0.96) 100%);
  border: 1rpx solid rgba(255, 183, 77, 0.18);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.55);
}

.points-label {
  font-size: 20rpx;
  color: #7d6546;
  line-height: 1.2;
}

.points {
  font-size: 32rpx;
  color: #ff9900;
  font-weight: 700;
  line-height: 1;
  flex-shrink: 0;
}

.stats-panel {
  display: flex;
  align-items: stretch;
  padding: 14rpx 0 12rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f1f6fd 100%);
  border: 1rpx solid rgba(93, 131, 191, 0.12);
  box-shadow: 0 3rpx 8rpx rgba(86, 115, 156, 0.05);
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 0 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-sizing: border-box;
}

.stat-item-highlight {
  position: relative;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #25364e;
  line-height: 1.1;
  text-align: center;
  flex-shrink: 0;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

.stat-value-highlight {
  color: #ff9900;
}

.stat-label {
  font-size: 20rpx;
  color: #7f8fa5;
  line-height: 1.2;
  white-space: nowrap;
}

.stat-divider {
  width: 1rpx;
  margin: 6rpx 0;
  background: rgba(126, 159, 209, 0.2);
  flex-shrink: 0;
}

.gear-icon {
  width: 28rpx;
  height: 28rpx;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.settings-btn:active .gear-icon {
  transform: rotate(24deg);
  opacity: 0.96;
}
