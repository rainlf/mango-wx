.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #2c3e50;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 300;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.drawer-open {
  transform: translateY(0);
}

.drawer-handle {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.handle-bar {
  width: 60rpx;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
}

.drawer-content {
  flex: 1;
  padding: 0 30rpx 40rpx;
  overflow-y: auto;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  margin-bottom: 20rpx;
  font-weight: bold;
}

/* 座位网格 */
.seats-grid {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
}

.seat-card {
  width: calc(50% - 8rpx);
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.seat-card.occupied {
  border-color: #3498db;
}

.seat-card.empty {
  border-style: dashed;
}

.seat-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.seat-name {
  color: #fff;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.seat-placeholder {
  color: rgba(255, 255, 255, 0.3);
  font-size: 60rpx;
  font-weight: 300;
}

/* 玩家列表 */
.player-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.player-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border: 2rpx solid transparent;
}

.player-item.selected {
  border-color: #2ecc71;
  background-color: rgba(46, 204, 113, 0.15);
}

.player-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.player-name {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  margin-top: 8rpx;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-bottom: 40rpx;
}

.btn-confirm {
  flex: 2;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #2ecc71;
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-confirm[disabled] {
  background-color: rgba(46, 204, 113, 0.3);
  color: rgba(255, 255, 255, 0.4);
}

.btn-confirm::after,
.btn-back::after {
  border: none;
}

.btn-back {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

/* 类型选择 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-card {
  width: calc(50% - 8rpx);
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 30rpx;
  border: 2rpx solid transparent;
}

.type-card.active {
  border-color: #3498db;
  background-color: rgba(52, 152, 219, 0.2);
  color: #3498db;
}

/* 赢家/输家选择 */
.player-select-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.player-select-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background-color: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.player-select-card.winner {
  border-color: #f1c40f;
  background-color: rgba(241, 196, 15, 0.15);
}

.player-select-card.loser {
  border-color: #e74c3c;
  background-color: rgba(231, 76, 60, 0.15);
}

.ps-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.ps-name {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 底分选择 */
.base-points-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.bp-card {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.bp-card.active {
  border-color: #e67e22;
  background-color: rgba(230, 126, 34, 0.2);
  color: #e67e22;
}

.custom-bp-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin-top: 20rpx;
}

.bp-adjust {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  color: #fff;
  font-size: 36rpx;
}

.bp-value {
  color: #e67e22;
  font-size: 36rpx;
  font-weight: bold;
  min-width: 60rpx;
  text-align: center;
}

/* 番型选择 */
.win-type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.wt-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.06);
  border-radius: 10rpx;
  border: 2rpx solid transparent;
}

.wt-card.active {
  border-color: #9b59b6;
  background-color: rgba(155, 89, 182, 0.2);
}

.wt-name {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.wt-multi {
  color: rgba(255, 255, 255, 0.4);
  font-size: 20rpx;
  margin-top: 4rpx;
}

/* 运动信息 */
.yundong-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background-color: rgba(46, 204, 113, 0.1);
  border-radius: 12rpx;
}

.yundong-text {
  color: #2ecc71;
  font-size: 28rpx;
}
