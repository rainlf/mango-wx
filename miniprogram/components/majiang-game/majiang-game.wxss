/* 抽屉样式 */
.drawer-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 999;
}

.mask {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(4rpx);
}

.drawer-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 88vh;
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(247, 250, 255, 0.99) 100%);
    border-radius: 32rpx 32rpx 0 0;
    box-shadow: 0 -14rpx 42rpx rgba(49, 68, 92, 0.18);
    overflow: hidden;
}

.drawer-handle {
    width: 88rpx;
    height: 10rpx;
    border-radius: 999rpx;
    background: rgba(126, 159, 209, 0.35);
    margin: 12rpx auto 0;
    flex-shrink: 0;
}

.drawer-header {
    display: flex;
    align-items: flex-start;
    gap: 20rpx;
    padding: 14rpx 22rpx 12rpx;
    flex-shrink: 0;
}

.drawer-header-text {
    flex: 1;
    min-width: 0;
}

.drawer-title {
    display: block;
    font-size: 34rpx;
    line-height: 1.15;
    font-weight: 700;
    color: #1f2f45;
}

.drawer-close {
    flex-shrink: 0;
    padding: 10rpx 18rpx;
    border-radius: 999rpx;
    background: rgba(74, 144, 226, 0.08);
    border: 1rpx solid rgba(126, 159, 209, 0.16);
    color: #4a8192;
    font-size: 22rpx;
    font-weight: 600;
}

.drawer-scroll {
    flex: 1;
    min-height: 0;
}

.drawer-content-top {
    padding: 2rpx 16rpx 14rpx;
    box-sizing: border-box;
}

.panel-card,
.section-card,
.detail-box {
    border-radius: 20rpx;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 252, 255, 0.98) 100%);
    border: 1rpx solid rgba(126, 159, 209, 0.14);
    box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.08);
}

.panel-card,
.section-card {
    margin: 0 0 14rpx;
    padding: 18rpx;
}

.panel-heading {
    display: flex;
    flex-direction: column;
    gap: 4rpx;
    margin-bottom: 14rpx;
}

.panel-title {
    font-size: 26rpx;
    font-weight: 700;
    color: #27384f;
}

.type-buttons {
    display: flex;
    gap: 12rpx;
}

.type-btn {
    flex: 1;
    min-width: 0;
    text-align: center;
    padding: 14rpx 10rpx;
    border-radius: 999rpx;
    background: linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%);
    border: 1rpx solid rgba(126, 159, 209, 0.12);
    color: #5f728b;
    font-size: 26rpx;
    font-weight: 600;
    box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
    transition: all 0.2s ease;
}

.type-btn.active {
    background: linear-gradient(135deg, #5ba5ff 0%, #377dff 100%);
    border-color: rgba(55, 125, 255, 0.2);
    color: #fff;
    box-shadow: 0 10rpx 22rpx rgba(55, 125, 255, 0.22);
}

.section-header {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.section-title-user {
    font-size: 28rpx;
    font-weight: 700;
    color: #25364c;
}

.section-subtitle {
    margin-left: auto;
    font-size: 22rpx;
    color: #6b7f98;
}

.replace-btn {
    margin-left: auto;
    padding: 10rpx 16rpx;
    border-radius: 999rpx;
    background: rgba(132, 118, 230, 0.08);
    border: 1rpx solid rgba(132, 118, 230, 0.12);
    color: #6c63a8;
    font-size: 22rpx;
    font-weight: 600;
}

.section-header-secondary {
    margin-bottom: 8rpx;
}

.players-grid,
.all-players-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12rpx;
    margin-top: 14rpx;
}

.players-grid-four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
}

.table-players-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12rpx;
    margin-top: 14rpx;
}

.player-card,
.all-player-card,
.table-player-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 136rpx;
    padding: 14rpx 10rpx;
    border-radius: 18rpx;
    background: linear-gradient(180deg, #fbfdff 0%, #f1f6fd 100%);
    border: 1rpx solid rgba(126, 159, 209, 0.12);
    box-shadow: 0 6rpx 18rpx rgba(86, 115, 156, 0.06);
    box-sizing: border-box;
    transition: all 0.2s ease;
}

.winner-card.winner-selected {
    background: linear-gradient(180deg, rgba(234, 251, 242, 0.98) 0%, rgba(223, 247, 233, 0.98) 100%);
    border-color: rgba(52, 199, 89, 0.22);
    box-shadow: 0 8rpx 18rpx rgba(52, 199, 89, 0.14);
}

.loser-card.loser-selected {
    background: linear-gradient(180deg, rgba(255, 244, 244, 0.98) 0%, rgba(255, 235, 235, 0.98) 100%);
    border-color: rgba(239, 68, 68, 0.2);
    box-shadow: 0 8rpx 18rpx rgba(239, 68, 68, 0.12);
}

.player-card-focus,
.all-player-card.last-active,
.detail-box.last-active {
    border-color: rgba(132, 118, 230, 0.2);
    box-shadow: 0 10rpx 24rpx rgba(132, 118, 230, 0.14);
}

.disabled-card {
    opacity: 0.6;
    filter: grayscale(0.15);
    background: linear-gradient(180deg, #f5f7fb 0%, #eef2f7 100%);
}

.disabled-card .player-name,
.disabled-card .player-state {
    color: #99a8bc;
}

.table-player-card.filled {
    border-color: rgba(74, 144, 226, 0.18);
}

.table-player-card.empty {
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.98) 0%, rgba(241, 245, 249, 0.98) 100%);
    border-style: dashed;
    border-color: rgba(148, 163, 184, 0.32);
}

.empty-seat-icon {
    width: 72rpx;
    height: 72rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(226, 232, 240, 0.92);
    color: #64748b;
    font-size: 42rpx;
    margin-bottom: 12rpx;
}

.empty-seat-text {
    font-size: 22rpx;
    color: #94a3b8;
}

.all-player-card.active {
    background: linear-gradient(180deg, rgba(238, 250, 255, 0.98) 0%, rgba(225, 244, 255, 0.98) 100%);
    border-color: rgba(0, 162, 194, 0.2);
    box-shadow: 0 10rpx 22rpx rgba(0, 162, 194, 0.12);
}

.player-avatar {
    width: 76rpx;
    height: 76rpx;
    border-radius: 50%;
    border: 4rpx solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 6rpx 18rpx rgba(74, 144, 226, 0.12);
}

.player-avatar {
    margin-bottom: 10rpx;
}

.player-name {
    max-width: 100%;
    font-size: 25rpx;
    line-height: 1.25;
    font-weight: 700;
    color: #26374d;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.detail-box {
    margin: 0 0 14rpx;
    padding: 18rpx;
}

.detail-content {
    width: 100%;
}

.detail-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10rpx;
}

.detail-score {
    display: inline-flex;
    align-items: center;
    gap: 8rpx;
    padding: 8rpx 14rpx;
    border-radius: 999rpx;
    background: linear-gradient(135deg, rgba(255, 248, 220, 0.98) 0%, rgba(255, 238, 196, 0.98) 100%);
    border: 1rpx solid rgba(255, 183, 77, 0.2);
    box-shadow: 0 4rpx 12rpx rgba(255, 183, 77, 0.12);
}

.detail-score-label {
    font-size: 20rpx;
    line-height: 1;
    color: #8f6a2f;
}

.detail-score-value {
    font-size: 30rpx;
    line-height: 1;
    font-weight: 700;
    color: #ff9f1a;
}

.delete-btn {
    width: 48rpx;
    height: 48rpx;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 86, 86, 0.1);
    border: 1rpx solid rgba(255, 86, 86, 0.12);
    color: #ef4444;
    font-size: 30rpx;
    box-shadow: 0 4rpx 10rpx rgba(239, 68, 68, 0.08);
}

.delete-btn-hover {
    background: rgba(255, 86, 86, 0.18) !important;
    transform: scale(0.96);
}

.formula-card {
    margin-top: 10rpx;
    padding: 14rpx 16rpx;
    border-radius: 16rpx;
    background: linear-gradient(135deg, rgba(255, 250, 236, 0.96) 0%, rgba(243, 248, 255, 0.96) 100%);
    border: 1rpx solid rgba(255, 183, 77, 0.16);
}

.formula-label {
    display: block;
    font-size: 20rpx;
    color: #7f6a49;
}

.formula-values {
    display: flex;
    align-items: center;
    gap: 8rpx;
    margin-top: 8rpx;
    flex-wrap: wrap;
}

.formula-main,
.formula-result {
    min-width: 48rpx;
    padding: 6rpx 10rpx;
    text-align: center;
    border-radius: 14rpx;
    background: rgba(255, 255, 255, 0.78);
    color: #31445c;
    font-size: 26rpx;
    font-weight: 700;
}

.formula-sign {
    font-size: 24rpx;
    font-weight: 700;
    color: #8f6a2f;
}

.formula-result {
    color: #ff9f1a;
}

.section {
    margin-top: 16rpx;
}

.section-title {
    display: block;
    margin-bottom: 12rpx;
    font-size: 24rpx;
    font-weight: 700;
    color: #42566f;
}

.button-row {
    display: flex;
    align-items: flex-start;
    gap: 12rpx;
}

.tag-group,
.tile-group {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10rpx;
}

.tag-btn,
.tile-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 52rpx;
    padding: 0 18rpx;
    border-radius: 14rpx;
    background: linear-gradient(180deg, #f5f8fc 0%, #edf2f8 100%);
    border: 1rpx solid rgba(126, 159, 209, 0.12);
    color: #5f728b;
    font-size: 24rpx;
    box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.tag-btn {
    min-width: 52rpx;
    padding: 0 14rpx;
}

.tag-btn.active,
.tile-btn.active {
    background: linear-gradient(135deg, #5ba5ff 0%, #377dff 100%);
    border-color: rgba(55, 125, 255, 0.18);
    color: #fff;
    box-shadow: 0 10rpx 22rpx rgba(55, 125, 255, 0.18);
}

.action-group {
    display: flex;
    gap: 10rpx;
    padding-top: 2rpx;
}

.action-btn {
    width: 52rpx;
    height: 52rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(180deg, #eef7ff 0%, #dfefff 100%);
    border: 1rpx solid rgba(74, 144, 226, 0.14);
    color: #2d6cdf;
    font-size: 30rpx;
    font-weight: 700;
    box-shadow: 0 6rpx 14rpx rgba(74, 144, 226, 0.1);
}

.action-btn-hover {
    background: linear-gradient(180deg, #e5f2ff 0%, #d0e6ff 100%) !important;
}

.scroll-view-container {
    width: 100%;
    height: 400rpx;
    margin-top: 12rpx;
}

.drawer-content-bottom {
    display: flex;
    align-items: center;
    gap: 14rpx;
    padding: 12rpx 16rpx calc(12rpx + env(safe-area-inset-bottom));
    border-top: 1rpx solid rgba(126, 159, 209, 0.12);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(248, 251, 255, 0.97) 100%);
    box-shadow: 0 -8rpx 20rpx rgba(62, 91, 135, 0.06);
    flex-shrink: 0;
}

.btn {
    flex: 1;
    min-height: 74rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999rpx;
    font-size: 28rpx;
    font-weight: 700;
    box-sizing: border-box;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.cancel {
    background: linear-gradient(180deg, #f7f9fc 0%, #edf2f8 100%);
    border: 1rpx solid rgba(126, 159, 209, 0.14);
    color: #5d7088;
    box-shadow: 0 6rpx 16rpx rgba(86, 115, 156, 0.06);
}

.confirm,
.confirm-wide {
    background: linear-gradient(135deg, #ffd86d 0%, #ffb300 100%);
    border: 1rpx solid rgba(214, 144, 0, 0.2);
    color: #fff;
    box-shadow: 0 10rpx 24rpx rgba(255, 183, 77, 0.24);
}

.confirm-wide {
    width: 100%;
}

.btn:active,
.type-btn:active,
.replace-btn:active,
.drawer-close:active,
.tag-btn:active,
.tile-btn:active,
.action-btn:active {
    transform: scale(0.98);
}

.tag-btn-hover,
.tile-btn-hover {
    transform: translateY(-1rpx);
}
