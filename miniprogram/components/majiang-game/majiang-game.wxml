<!-- 遮罩层 -->
<view class="mask" wx:if="{{showPanel}}" bindtap="closePanel"></view>

<!-- 抽屉面板 -->
<view class="drawer {{showPanel ? 'drawer-open' : ''}}">
  <!-- 拖动手柄 -->
  <view class="drawer-handle" bindtap="togglePanel">
    <view class="handle-bar"></view>
  </view>

  <scroll-view scroll-y class="drawer-content">
    <!-- 步骤1: 选择牌桌玩家 -->
    <view class="section" wx:if="{{step === 0}}">
      <view class="section-title">当前牌桌</view>
      
      <!-- 当前4个座位 -->
      <view class="seats-grid">
        <view
          class="seat-card {{item.id ? 'occupied' : 'empty'}}"
          wx:for="{{currentPlayers}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onSeatTap"
        >
          <image wx:if="{{item.id}}" class="seat-avatar" src="{{item.avatar || '/images/background.png'}}"></image>
          <text wx:if="{{item.id}}" class="seat-name">{{item.nickname || item.username}}</text>
          <text wx:else class="seat-placeholder">+</text>
        </view>
      </view>

      <!-- 所有可选玩家列表 -->
      <view class="section-title" style="margin-top: 30rpx;">选择玩家</view>
      <view class="player-list">
        <view
          class="player-item {{item.selected ? 'selected' : ''}}"
          wx:for="{{allPlayers}}"
          wx:key="id"
          data-player="{{item}}"
          bindtap="onPlayerSelect"
        >
          <image class="player-avatar" src="{{item.avatar || '/images/background.png'}}"></image>
          <text class="player-name">{{item.nickname || item.username}}</text>
        </view>
      </view>

      <!-- 确认换人 / 开始记录 -->
      <view class="action-bar">
        <button class="btn-confirm" bindtap="confirmPlayers" disabled="{{selectedCount !== 4}}">
          确认 ({{selectedCount}}/4)
        </button>
      </view>
    </view>

    <!-- 步骤2: 选择游戏类型 -->
    <view class="section" wx:if="{{step === 1}}">
      <view class="section-title">选择类型</view>
      <view class="type-grid">
        <view
          class="type-card {{gameType === 'hu' ? 'active' : ''}}"
          bindtap="selectGameType"
          data-type="hu"
        >
          <text>胡牌</text>
        </view>
        <view
          class="type-card {{gameType === 'zimo' ? 'active' : ''}}"
          bindtap="selectGameType"
          data-type="zimo"
        >
          <text>自摸</text>
        </view>
        <view
          class="type-card {{gameType === 'xiangong' ? 'active' : ''}}"
          bindtap="selectGameType"
          data-type="xiangong"
        >
          <text>相公</text>
        </view>
        <view
          class="type-card {{gameType === 'yundong' ? 'active' : ''}}"
          bindtap="selectGameType"
          data-type="yundong"
        >
          <text>运动</text>
        </view>
      </view>
    </view>

    <!-- 步骤3: 选择赢家/输家 + 底分 + 番型 -->
    <view class="section" wx:if="{{step === 2}}">
      <!-- 胡牌/自摸: 选择赢家 -->
      <view wx:if="{{gameType === 'hu' || gameType === 'zimo'}}">
        <view class="section-title">选择赢家</view>
        <view class="player-select-grid">
          <view
            class="player-select-card {{item.gameInfo.isWinner ? 'winner' : ''}}"
            wx:for="{{gamePlayers}}"
            wx:key="id"
            data-index="{{index}}"
            bindtap="toggleWinner"
          >
            <image class="ps-avatar" src="{{item.avatar || '/images/background.png'}}"></image>
            <text class="ps-name">{{item.nickname || item.username}}</text>
          </view>
        </view>
      </view>

      <!-- 相公: 选择相公者（输家） -->
      <view wx:if="{{gameType === 'xiangong'}}">
        <view class="section-title">谁相公了？</view>
        <view class="player-select-grid">
          <view
            class="player-select-card {{item.gameInfo.isLoser ? 'loser' : ''}}"
            wx:for="{{gamePlayers}}"
            wx:key="id"
            data-index="{{index}}"
            bindtap="toggleXiangongLoser"
          >
            <image class="ps-avatar" src="{{item.avatar || '/images/background.png'}}"></image>
            <text class="ps-name">{{item.nickname || item.username}}</text>
          </view>
        </view>
      </view>

      <!-- 运动: 显示记录者 -->
      <view wx:if="{{gameType === 'yundong'}}">
        <view class="section-title">运动奖励</view>
        <view class="yundong-info">
          <text class="yundong-text">记录者将获得运动积分 +10</text>
        </view>
      </view>

      <!-- 底分选择（胡牌/自摸时显示） -->
      <view wx:if="{{gameType === 'hu' || gameType === 'zimo'}}">
        <view class="section-title">底分</view>
        <view class="base-points-row">
          <view
            class="bp-card {{basePoints === item ? 'active' : ''}}"
            wx:for="{{basePointsList}}"
            wx:key="*this"
            data-points="{{item}}"
            bindtap="selectBasePoints"
          >
            <text>{{item === 10 ? '🍒' : item}}</text>
          </view>
        </view>
        <!-- 自定义加减 -->
        <view class="custom-bp-row">
          <view class="bp-adjust" bindtap="decreaseBasePoints">-</view>
          <text class="bp-value">{{basePoints}}</text>
          <view class="bp-adjust" bindtap="increaseBasePoints">+</view>
        </view>
      </view>

      <!-- 番型选择（胡牌/自摸时显示） -->
      <view wx:if="{{gameType === 'hu' || gameType === 'zimo'}}">
        <view class="section-title">番型 (倍率: x{{currentMulti}})</view>
        <view class="win-type-grid">
          <view
            class="wt-card {{item.selected ? 'active' : ''}}"
            wx:for="{{winTypeList}}"
            wx:key="code"
            data-index="{{index}}"
            bindtap="toggleWinType"
          >
            <text class="wt-name">{{item.name}}</text>
            <text class="wt-multi">x{{item.multiplier}}</text>
          </view>
        </view>
      </view>

      <!-- 提交按钮 -->
      <view class="action-bar">
        <button class="btn-back" bindtap="prevStep">返回</button>
        <button class="btn-confirm" bindtap="submitGame">提交</button>
      </view>
    </view>

    <!-- 返回到类型选择 -->
    <view class="action-bar" wx:if="{{step === 1}}">
      <button class="btn-back" bindtap="prevStep">返回</button>
    </view>
  </scroll-view>
</view>
