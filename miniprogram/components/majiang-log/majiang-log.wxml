<view class="log-container">
  <view class="log-title-bar">
    <text class="log-title">{{title || '对局记录'}}</text>
  </view>

  <scroll-view
    scroll-y
    class="log-scroll"
    bindscrolltolower="onScrollToLower"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{isRefreshing}}"
  >
    <view class="log-list">
      <view
        class="log-card {{item.forOnePlayer ? (item.playerWin ? 'card-win' : 'card-lose') : ''}}"
        wx:for="{{logList}}"
        wx:key="id"
      >
        <!-- 头部：类型 + 四个头像 + 时间 -->
        <view class="log-header">
          <text class="log-type">{{item.type}}</text>
          <view class="log-players-row">
            <image class="log-player-avatar" src="{{item.player1.avatar}}"></image>
            <image class="log-player-avatar" src="{{item.player2.avatar}}"></image>
            <image class="log-player-avatar" src="{{item.player3.avatar}}"></image>
            <image class="log-player-avatar" src="{{item.player4.avatar}}"></image>
          </view>
          <text class="log-time">{{item.createdTime}}</text>
          <image
            wx:if="{{item.deleteIcon}}"
            class="log-delete-icon"
            src="{{item.deleteIcon}}"
            data-game-id="{{item.id}}"
            catchtap="onDeleteTap"
          ></image>
        </view>

        <!-- 赢家区域 -->
        <view class="log-winners" wx:if="{{item.winners.length > 0}}">
          <view class="log-winner-item" wx:for="{{item.winners}}" wx:for-item="winner" wx:key="index">
            <image class="log-item-avatar" src="{{winner.user.avatar}}"></image>
            <view class="log-item-info">
              <text class="log-item-name">{{winner.user.nickname || winner.user.username}}</text>
              <view class="log-item-tags" wx:if="{{winner.tags.length > 0}}">
                <text class="log-tag" wx:for="{{winner.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
              </view>
            </view>
            <text class="log-item-points win-points">+{{winner.points}}</text>
          </view>
        </view>

        <!-- 输家区域 -->
        <view class="log-losers" wx:if="{{item.losers.length > 0}}">
          <view class="log-loser-item" wx:for="{{item.losers}}" wx:for-item="loser" wx:key="index">
            <image class="log-item-avatar" src="{{loser.user.avatar}}"></image>
            <view class="log-item-info">
              <text class="log-item-name">{{loser.user.nickname || loser.user.username}}</text>
            </view>
            <text class="log-item-points lose-points">{{loser.points}}</text>
          </view>
        </view>

        <!-- 记录者信息 -->
        <view class="log-recorder" wx:if="{{item.recorder && item.recorder.user && item.recorder.user.id}}">
          <text class="recorder-label">记录：{{item.recorder.user.nickname || item.recorder.user.username}}</text>
          <text class="recorder-points" wx:if="{{item.recorder.points > 0}}">+{{item.recorder.points}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more-tip" wx:if="{{isLoadingMore}}">
      <text>加载中...</text>
    </view>
    <view class="load-more-tip" wx:if="{{!isLoadingMore && logList.length > 0 && noMore}}">
      <text>没有更多了</text>
    </view>
    <view class="empty-tip" wx:if="{{!isLoadingMore && logList.length === 0}}">
      <text>暂无对局记录</text>
    </view>
  </scroll-view>
</view>
