/* 历史列表容器 */
.list-container {
    height: calc(100vh - 600rpx);
    display: flex;
    flex-direction: column;
    padding: 16rpx 20rpx;
    margin: 10rpx 20rpx 20rpx 20rpx;
    width: auto;
    box-sizing: border-box;
    border-radius: 22rpx;
    border: 1rpx solid rgba(126, 159, 209, 0.16);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 251, 255, 0.98) 100%);
    box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.1);
}

.list-content {
    flex: 1;
    width: 100%;
    min-height: 0;
}

/* 单条记录卡片 */
.record-item {
    margin: 14rpx 0;
    padding: 24rpx;
    border-radius: 20rpx;
    border: 1rpx solid rgba(93, 131, 191, 0.14);
    background: linear-gradient(180deg, #fbfdff 0%, #f2f7fe 100%);
    box-shadow:
        inset 0 1rpx 0 rgba(255, 255, 255, 0.72),
        0 6rpx 18rpx rgba(86, 115, 156, 0.08);
    box-sizing: border-box;
    min-height: 0;
}

.record-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18rpx;
    padding-bottom: 16rpx;
    border-bottom: 2rpx solid rgba(126, 159, 209, 0.12);
}

.record-header-left {
    display: flex;
    align-items: center;
    min-width: 0;
}

.record-header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14rpx;
    flex-shrink: 0;
}

.record-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6rpx;
    min-width: 0;
}

.win-type,
.win-type2 {
    min-width: 92rpx;
    padding: 8rpx 18rpx;
    border-radius: 999rpx;
    font-size: 24rpx;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    box-sizing: border-box;
}

.win-type {
    color: #1e8f67;
    background: linear-gradient(180deg, rgba(229, 250, 236, 0.98) 0%, rgba(210, 240, 220, 0.98) 100%);
    border: 1rpx solid rgba(33, 160, 110, 0.14);
}

.win-type2 {
    color: #c46811;
    background: linear-gradient(180deg, rgba(255, 248, 231, 0.98) 0%, rgba(255, 228, 176, 0.98) 100%);
    border: 1rpx solid rgba(222, 164, 62, 0.18);
}

.player-avatars {
    display: flex;
    align-items: center;
    margin-left: 18rpx;
}

.avatar-small {
    width: 38rpx;
    height: 38rpx;
    margin-left: -10rpx;
    border-radius: 50%;
    border: 2rpx solid rgba(255, 255, 255, 0.98);
    box-shadow: 0 3rpx 8rpx rgba(74, 144, 226, 0.1);
    background: #fff;
}

.avatar-small:first-child {
    margin-left: 0;
}

.game-time {
    padding: 8rpx 14rpx;
    border-radius: 999rpx;
    font-size: 22rpx;
    font-weight: 500;
    line-height: 1;
    color: #6f8198;
    background: rgba(255, 255, 255, 0.82);
    border: 1rpx solid rgba(126, 159, 209, 0.14);
}

.recorder-info {
    font-size: 20rpx;
    line-height: 1.1;
    color: #9aa8b8;
    max-width: 260rpx;
    margin-right: 16rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.delete-btn {
    width: 34rpx;
    height: 34rpx;
    padding: 10rpx;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(255, 245, 245, 0.98) 0%, rgba(255, 235, 235, 0.98) 100%);
    border: 1rpx solid rgba(239, 68, 68, 0.12);
    box-shadow: 0 4rpx 10rpx rgba(239, 68, 68, 0.08);
}

.winner-section,
.loser-section {
    overflow: hidden;
    border-radius: 16rpx;
}

.player-row {
    display: flex;
    align-items: center;
    padding: 16rpx 0;
    box-sizing: border-box;
}

.winner-section .player-row + .player-row,
.loser-section .player-row + .player-row {
    border-top: 1rpx solid rgba(126, 159, 209, 0.1);
}

.winner {
    background: linear-gradient(180deg, rgba(255, 249, 249, 0.94) 0%, rgba(255, 244, 244, 0.94) 100%);
}

.loser {
    background: linear-gradient(180deg, rgba(241, 252, 246, 0.94) 0%, rgba(233, 249, 240, 0.94) 100%);
}

.avatar {
    width: 64rpx;
    height: 64rpx;
    margin-right: 18rpx;
    border-radius: 50%;
    border: 4rpx solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 6rpx 16rpx rgba(74, 144, 226, 0.1);
    box-sizing: border-box;
    flex-shrink: 0;
}

.player-info {
    flex: 1;
    min-width: 0;
    margin-right: 16rpx;
}

.nickname {
    display: block;
    margin-bottom: 8rpx;
    font-size: 28rpx;
    font-weight: 700;
    color: #22344b;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8rpx;
}

.tag {
    padding: 4rpx 14rpx;
    border-radius: 999rpx;
    font-size: 21rpx;
    line-height: 1.35;
    font-weight: 500;
}

.win-tag {
    color: #4f84c4;
    background: rgba(111, 179, 255, 0.12);
}

.lose-tag {
    color: #4f84c4;
    background: rgba(111, 179, 255, 0.12);
}

.draw-tag {
    color: #2d5f98;
    background: rgba(74, 144, 226, 0.1);
}

.score-change,
.score-change2 {
    min-width: 104rpx;
    text-align: right;
    font-size: 34rpx;
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
}

.score-change {
    color: #ff9900;
    text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.42);
}

.score-change2 {
    color: #2f9b63;
    text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.42);
}

.loading-more,
.no-more-data {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    padding: 18rpx 0 10rpx;
    font-size: 24rpx;
    color: #7c8ea5;
}

.loading-spinner {
    width: 24rpx;
    height: 24rpx;
    border-radius: 50%;
    border: 3rpx solid rgba(74, 144, 226, 0.18);
    border-top-color: #ffb300;
    border-right-color: #4a90e2;
    box-sizing: border-box;
    animation: log-spin 0.9s linear infinite;
}

@keyframes log-spin {
    from {
        transform: rotate(0deg);
    }
    to {
        transform: rotate(360deg);
    }
}

@media screen and (max-width: 375rpx) {
    .list-container {
        margin: 5rpx 10rpx 10rpx 10rpx;
        padding: 14rpx 16rpx;
    }

    .record-item {
        padding: 20rpx;
    }

    .win-type,
    .win-type2 {
        min-width: 82rpx;
        padding: 8rpx 14rpx;
        font-size: 22rpx;
    }

    .recorder-info {
        max-width: 220rpx;
        font-size: 18rpx;
    }

    .nickname {
        font-size: 26rpx;
    }

    .score-change,
    .score-change2 {
        min-width: 92rpx;
        font-size: 30rpx;
    }
}
