/* 列表容器样式 */
.list-container {
    height: calc(100vh - 600rpx); /* 与玩家排行页面使用相同的高度计算方式 */
    display: flex;
    flex-direction: column;
    padding: 16rpx 20rpx;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 252, 255, 0.98) 100%);
    border-radius: 22rpx;
    box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.1);
    margin: 10rpx 20rpx 20rpx 20rpx;
    border: 1rpx solid rgba(126, 159, 209, 0.16);
    width: auto;
}

/* 确保内容容器不会限制列表项的高度 */
.list-content {
    flex: 1;
    width: 100%;
    min-height: 0; /* 解决flex布局中子元素高度计算问题 */
}

/* 记录项容器 */
.record-item {
    background: #fff;
    border-radius: 12rpx;
    margin: 20rpx;
    padding: 24rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
    min-height: 0; /* 确保记录项不会导致flex容器过度拉伸 */
}


/* 记录项容器 */
.record-item {
    background: #fff;
    border-radius: 12rpx;
    margin: 20rpx;
    padding: 24rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 头部信息 */
.record-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20rpx;
    padding-bottom: 16rpx;
    border-bottom: 2rpx solid #eee;
}

.record-header-left {
    display: flex;
    justify-content: start;
    align-items: center;
}

.record-header-right {
    display: flex;
    justify-content: end;
    align-items: center;
}

.win-type {
    font-size: 32rpx;
    font-weight: 700;
    color: #00b894;
}

.win-type2 {
    font-size: 32rpx;
    font-weight: 700;
    color: orangered;
}

.game-time {
    font-size: 24rpx;
    color: #666;
}

/* 玩家行 */
.player-row {
    display: flex;
    align-items: center;
    padding: 16rpx 0;
}

.avatar {
    width: 64rpx;
    height: 64rpx;
    border-radius: 50%;
    margin-right: 20rpx;
}

.player-info {
    flex: 1;
    margin-right: 20rpx;
}

.nickname {
    font-size: 28rpx;
    color: #333;
    margin-bottom: 8rpx;
}

.tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8rpx;
}

.tag {
    font-size: 22rpx;
    padding: 4rpx 16rpx;
    border-radius: 32rpx;
    margin-right: 10rpx;
    margin-bottom: 10rpx;
}

.win-tag {
    background: #d0f0d7;
    color: #059669;
}

.lose-tag {
    background: #fef2f2;
    color: #dc2626;
}

.draw-tag {
    background: #f0f9ff;
    color: #0284c7;
}

/* 分数显示 */
.score {
    font-size: 32rpx;
    font-weight: 700;
    text-align: right;
    min-width: 120rpx;
}

.win-score {
    color: #10b981;
}

.lose-score {
    color: #ef4444;
}

.draw-score {
    color: #64748b;
}

/* 底部操作按钮 */
.bottom-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 16rpx;
    padding-top: 16rpx;
    border-top: 2rpx solid #eee;
}

.action-btn {
    font-size: 24rpx;
    padding: 8rpx 24rpx;
    border-radius: 32rpx;
    background: #f3f4f6;
    color: #6b7280;
    transition: all 0.3s ease;
}

.action-btn:active {
    background: #e5e7eb;
}

/* 删除弹窗样式 */
.delete-confirm {
    width: 80%;
    max-width: 500rpx;
    border-radius: 20rpx;
    overflow: hidden;
}

.delete-title {
    font-size: 32rpx;
    font-weight: 700;
    text-align: center;
    padding: 32rpx 24rpx;
    color: #333;
}

.delete-content {
    font-size: 28rpx;
    text-align: center;
    padding: 0 24rpx 32rpx 24rpx;
    color: #666;
}

.delete-buttons {
    display: flex;
    border-top: 2rpx solid #eee;
}

.delete-btn-cancel {
    flex: 1;
    padding: 32rpx 24rpx;
    font-size: 28rpx;
    text-align: center;
    color: #666;
    border-right: 2rpx solid #eee;
}

.delete-btn-confirm {
    flex: 1;
    padding: 32rpx 24rpx;
    font-size: 28rpx;
    text-align: center;
    color: #ef4444;
    font-weight: 700;
}

/* 加载更多样式 */
.load-more {
    padding: 20rpx 0;
    text-align: center;
    font-size: 24rpx;
    color: #999;
}

/* 空列表样式 */
.empty-list {
    padding: 100rpx 0;
    text-align: center;
}

.empty-icon {
    width: 160rpx;
    height: 160rpx;
    margin-bottom: 20rpx;
    opacity: 0.5;
}

.empty-text {
    font-size: 28rpx;
    color: #999;
}

/* 头像容器和小头像 */
.player-avatars {
    display: flex;
    align-items: center;
    margin-left: 20rpx;
}

.avatar-small {
    width: 36rpx;
    height: 36rpx;
    border-radius: 50%;
    margin-left: -10rpx;
    border: 2rpx solid white;
}

/* 删除按钮样式 */
.delete-btn {
    width: 40rpx;
    height: 40rpx;
    margin-left: 20rpx;
}

/* 玩家信息样式增强 */
.player-detail {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.player-stats {
    display: flex;
    align-items: center;
    margin-top: 8rpx;
    font-size: 22rpx;
    color: #888;
}

.stat-item {
    margin-right: 20rpx;
    display: flex;
    align-items: center;
}

.stat-icon {
    width: 22rpx;
    height: 22rpx;
    margin-right: 6rpx;
}

/* 玩家详情弹窗样式 */
.player-detail-popup {
    width: 90%;
    max-width: 600rpx;
    border-radius: 20rpx;
    overflow: hidden;
}

.player-detail-header {
    padding: 32rpx 24rpx;
    text-align: center;
    background: #f3f4f6;
}

.player-detail-avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    margin: 0 auto 16rpx auto;
}

.player-detail-name {
    font-size: 32rpx;
    font-weight: 700;
    color: #333;
}

.player-detail-stats {
    padding: 32rpx 24rpx;
}

.player-detail-stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16rpx 0;
    border-bottom: 2rpx solid #eee;
}

.player-detail-stat-label {
    font-size: 28rpx;
    color: #666;
}

.player-detail-stat-value {
    font-size: 28rpx;
    font-weight: 700;
    color: #333;
}

.player-detail-close {
    padding: 32rpx 24rpx;
    text-align: center;
    font-size: 28rpx;
    font-weight: 700;
    color: #666;
    border-top: 2rpx solid #eee;
}

/* 自定义按钮样式增强 */
.custom-button {
    display: inline-block;
    padding: 12rpx 32rpx;
    border-radius: 32rpx;
    font-size: 24rpx;
    font-weight: 700;
    text-align: center;
    transition: all 0.3s ease;
    margin: 0 10rpx;
}

.custom-button-primary {
    background: #3b82f6;
    color: white;
}

.custom-button-primary:active {
    background: #2563eb;
}

.custom-button-secondary {
    background: #f3f4f6;
    color: #6b7280;
}

.custom-button-secondary:active {
    background: #e5e7eb;
}

/* 响应式布局调整 */
@media screen and (max-width: 375rpx) {
    .list-container {
        margin: 5rpx 10rpx 10rpx 10rpx;
    }
    
    .record-item {
        margin: 10rpx;
        padding: 16rpx;
    }
    
    .nickname {
        font-size: 24rpx;
    }
    
    .score {
        font-size: 28rpx;
    }
}
