.log-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.log-title-bar {
  padding: 20rpx 30rpx;
}

.log-title {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  font-weight: bold;
}

.log-scroll {
  flex: 1;
  height: 0;
}

.log-list {
  padding: 0 20rpx;
}

.log-card {
  background-color: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid transparent;
}

.log-card.card-win {
  border-left-color: #f1c40f;
}

.log-card.card-lose {
  border-left-color: #e74c3c;
}

/* 头部 */
.log-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.log-type {
  color: #3498db;
  font-size: 26rpx;
  font-weight: bold;
  min-width: 80rpx;
}

.log-players-row {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.log-player-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.log-time {
  color: rgba(255, 255, 255, 0.3);
  font-size: 22rpx;
}

.log-delete-icon {
  width: 36rpx;
  height: 36rpx;
  margin-left: 12rpx;
}

/* 赢家/输家区域 */
.log-winners,
.log-losers {
  margin-bottom: 12rpx;
}

.log-winner-item,
.log-loser-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 16rpx;
}

.log-item-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.log-item-info {
  flex: 1;
}

.log-item-name {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
}

.log-item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 6rpx;
}

.log-tag {
  color: rgba(255, 255, 255, 0.5);
  font-size: 20rpx;
  background-color: rgba(255, 255, 255, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.log-item-points {
  font-size: 30rpx;
  font-weight: bold;
}

.win-points {
  color: #f1c40f;
}

.lose-points {
  color: #e74c3c;
}

/* 记录者 */
.log-recorder {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.recorder-label {
  color: rgba(255, 255, 255, 0.3);
  font-size: 22rpx;
}

.recorder-points {
  color: #2ecc71;
  font-size: 22rpx;
}

/* 加载提示 */
.load-more-tip,
.empty-tip {
  display: flex;
  justify-content: center;
  padding: 30rpx;
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
}
