<scroll-view
        class="list-container"
        scroll-y
        refresher-enabled
        bindrefresherrefresh="onRefresh"
        refresher-triggered="{{isRefreshing}}"
>
    <view class="list-content">
        <view class="panel-banner">
            <view class="panel-banner__tabs">
                <view
                    class="panel-banner__tab {{rankMode === 'points' ? 'panel-banner__tab-active' : ''}}"
                    catch:tap="switchRankMode"
                    data-mode="points"
                >
                    金币榜
                </view>
                <view
                    class="panel-banner__tab {{rankMode === 'winRate' ? 'panel-banner__tab-active' : ''}}"
                    catch:tap="switchRankMode"
                    data-mode="winRate"
                >
                    胜率榜
                </view>
            </view>
            <view class="panel-banner__worst">
                <text class="panel-banner__worst-title">全程最菜 🥬  居然是Ta 👉</text>
                <block wx:if="{{worstUser}}">
                    <view class="panel-banner__worst-user">
                        <image class="panel-banner__worst-avatar" src="{{worstUser.avatar}}" mode="aspectFill" />
                        <text class="panel-banner__worst-name">{{worstUser.username}}</text>
                    </view>
                    <view class="panel-banner__worst-metrics">
                        <view class="panel-banner__worst-metric">
                            <text class="panel-banner__worst-value">{{worstUser.worstPointsText}}</text>
                            <text class="panel-banner__worst-label">金币</text>
                        </view>
                        <view class="panel-banner__worst-metric">
                            <text class="panel-banner__worst-value">{{worstUser.worstWinRateText}}</text>
                            <text class="panel-banner__worst-label">胜率</text>
                        </view>
                    </view>
                </block>
                <text wx:else class="panel-banner__worst-empty">暂无玩家</text>
            </view>
        </view>
        <block wx:for="{{displayList}}" wx:key="id">
            <view class="list-item">
                <!-- 排名徽章 -->

                <view wx:if="{{index === 0}}">
                    <view class="rank-king-box">
                    <image class="rank-king" src="/images/king1.png" mode="aspectFill"/>
                    </view>
                </view>
                <view wx:elif="{{index === 1}}">
                    <view class="rank-king-box">
                        <image class="rank-king" src="/images/king2.png" mode="aspectFill"/>
                    </view>
                </view>
                <view wx:elif="{{index === 2}}">
                    <view class="rank-king-box">
                        <image class="rank-king" src="/images/king3.png" mode="aspectFill"/>
                    </view>
                </view>
                <view wx:else>
                    <view class="rank-box {{index < 10 ? 'rank-box-ring' : ''}}">
                        <text class="rank-text">{{index + 1}}</text>
                    </view>
                </view>


                <!-- 昵称和标签区 -->
                <view class="info-box">
                    <view class="user-info-box">
                        <image class="avatar" src="{{item.avatar}}" mode="aspectFill" catch:tap="clickUserAvatar" data-id="{{item.id}}" data-username="{{item.username}}"/>
                        <text class="nickname">{{item.username}}</text>
                    </view>
                    <view class="tags-box">
                        <block wx:for="{{item.displayTags}}" wx:key="index">
                            <text wx:if="{{item === '一炮双响' || item === '一炮三响' || item === '相公'}}" class="tag2">{{item}}</text>
                            <text wx:else class="tag">{{item}}</text>
                        </block>
                        <text wx:if="{{item.canToggleTags}}" class="tag tag-more" catch:tap="toggleTags" data-id="{{item.id}}">{{item.isTagsExpanded ? '收起' : '+' + item.hiddenTagCount}}</text>
                    </view>
                </view>

                <!-- 得分展示 -->
                <view class="score-box">
                    <block wx:if="{{item.rankMetricPositive}}">
                        <text class="score-text">{{item.rankMetricText}}</text>
                    </block>
                    <block wx:else>
                        <text class="score-text2">{{item.rankMetricText}}</text>
                    </block>
                    <view class="score-meta">
                        <view class="coin-icon coin-icon-sm">
                            <view class="coin-icon-inner coin-icon-inner-sm"></view>
                        </view>
                        <text class="score-label">{{item.rankMetricLabel}}</text>
                    </view>
                </view>
            </view>
        </block>
    </view>
</scroll-view>
