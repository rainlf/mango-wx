.list-container {
    height: calc(100vh - 600rpx); /* 根据userinfo高度调整 */
    display: flex;
    align-items: center;
    padding: 16rpx 20rpx;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 252, 255, 0.98) 100%);
    border-radius: 22rpx;
    box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.1);
    margin: 10rpx 20rpx 20rpx 20rpx;
    border: 1rpx solid rgba(126, 159, 209, 0.16);
    width: auto;
}

@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* 加载动画 */
.dot-flashing {
    position: relative;
    width: 10rpx;
    height: 10rpx;
    border-radius: 5rpx;
    background-color: #4a90e2;
    color: #4a90e2;
    animation: dotFlashing 1s infinite linear;
}

.dot-flashing::before, .dot-flashing::after {
    content: '';
    display: inline-block;
    position: absolute;
    top: 0;
}

.dot-flashing::before {
    left: -15rpx;
    width: 10rpx;
    height: 10rpx;
    border-radius: 5rpx;
    background-color: #4a90e2;
    color: #4a90e2;
    animation: dotFlashing 1s infinite linear;
    animation-delay: 0s;
}

.dot-flashing::after {
    left: 15rpx;
    width: 10rpx;
    height: 10rpx;
    border-radius: 5rpx;
    background-color: #4a90e2;
    color: #4a90e2;
    animation: dotFlashing 1s infinite linear;
    animation-delay: 0.5s;
}

@keyframes dotFlashing {
    0% { background-color: #4a90e2; }
    50%, 100% { background-color: rgba(74,144,226,0.2); }
}
/* 列表项容器 */
.list-item {
    display: flex;
    align-items: center;
    gap: 16rpx;
    padding: 16rpx 16rpx;
    margin: 12rpx 0;
    background: linear-gradient(180deg, #fbfdff 0%, #f1f6fd 100%);
    border-radius: 18rpx;
    border: 1rpx solid rgba(93, 131, 191, 0.14);
    box-shadow: 0 3rpx 10rpx rgba(86, 115, 156, 0.06);
}

.user-info-box {
    display: flex;
    flex-direction: row;
    justify-content: start;
    align-items: center;
    gap: 16rpx;
    margin-bottom: 8rpx;
}

/* 排名样式 */
.rank-king-box {
    min-width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(255, 251, 242, 0.98) 0%, rgba(255, 240, 204, 0.98) 100%);
    border: 1rpx solid rgba(255, 183, 77, 0.24);
    box-shadow: 0 4rpx 10rpx rgba(255, 183, 77, 0.1);
}

.rank-box {
    min-width: 80rpx;
    height: 80rpx;
    /* Match top-3 badge base tone */
    background: linear-gradient(135deg, rgba(255, 251, 242, 0.98) 0%, rgba(255, 240, 204, 0.98) 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1rpx solid rgba(255, 183, 77, 0.24);
    box-shadow:
      inset 0 1rpx 0 rgba(255, 255, 255, 0.82),
      0 4rpx 10rpx rgba(255, 183, 77, 0.1);
    position: relative;
}

.rank-box::after {
    content: '';
    position: absolute;
    left: 8rpx;
    top: 8rpx;
    right: 8rpx;
    bottom: 8rpx;
    border-radius: 50%;
    border: 1rpx solid rgba(255, 183, 77, 0.16);
    box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
    pointer-events: none;
}

.rank-box-ring::after {
    content: '';
    position: absolute;
    left: 7rpx;
    top: 7rpx;
    right: 7rpx;
    bottom: 7rpx;
    border-radius: 50%;
    border: 1rpx solid rgba(255, 183, 77, 0.2);
    box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
    pointer-events: none;
}

.rank-king {
    width: 100%;
    height: 100%;
    padding: 15%;  /* 可视情况调整留白 */
    object-fit: contain;
}

.rank-text {
    color: #8f6a2f;
    font-size: 32rpx;
    font-weight: 700;
    text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.55);
}

/* 头像样式 */
.avatar {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    border: 4rpx solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 6rpx 18rpx rgba(74, 144, 226, 0.1);
}

/* 信息区 */
.info-box {
    flex: 1;
    min-width: 0;
}

.nickname {
    font-size: 34rpx;
    font-weight: 700;
    color: #1f2f45;
    margin-bottom: 8rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.tags-box {
    display: flex;
    flex-wrap: wrap;
    gap: 10rpx;
}

.tag {
    background: rgba(74, 144, 226, 0.12);
    color: #2d5f98;
    font-size: 22rpx;
    padding: 6rpx 14rpx;
    border-radius: 999rpx;
    line-height: 1.4;
}

.tag2 {
    background: rgba(255, 183, 77, 0.16);
    color: #b24b00;
    font-size: 22rpx;
    padding: 6rpx 14rpx;
    border-radius: 999rpx;
    line-height: 1.4;
}

/* 得分样式 */
.score-box {
    text-align: right;
    min-width: 140rpx;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    gap: 8rpx;
}

.score-text {
    display: block;
    font-size: 40rpx;
    font-weight: 700;
    color: #ff9900;
    line-height: 1;
}

.score-text2 {
    display: block;
    font-size: 40rpx;
    font-weight: 700;
    color: #2f9b63;
    line-height: 1;
}

.score-meta {
    display: flex;
    align-items: center;
    gap: 8rpx;
}

.score-label {
    font-size: 22rpx;
    color: #7d6546;
    opacity: 0.92;
}

.coin-icon {
    width: 24rpx;
    height: 24rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #ffd66b 0%, #ffb300 100%);
    border: 1rpx solid rgba(214, 144, 0, 0.35);
    box-shadow:
      inset 0 1rpx 0 rgba(255, 248, 220, 0.8),
      0 2rpx 4rpx rgba(255, 183, 77, 0.16);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.coin-icon-inner {
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
    background: rgba(255, 241, 196, 0.75);
}

.coin-icon-sm {
    width: 22rpx;
    height: 22rpx;
}

.coin-icon-inner-sm {
    width: 9rpx;
    height: 9rpx;
}
