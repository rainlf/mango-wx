.rank-container {
  flex: 1;
  height: 0;
}

.rank-list {
  padding: 10rpx 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  margin-bottom: 8rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  gap: 16rpx;
}

.rank-badge {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-crown {
  width: 48rpx;
  height: 48rpx;
}

.rank-number {
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
  font-weight: bold;
}

.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.rank-avatar-placeholder {
  background-color: rgba(255, 255, 255, 0.12);
}

.rank-info {
  flex: 1;
}

.rank-name {
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
}

.rank-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 6rpx;
  flex-wrap: wrap;
}

.rank-tag {
  color: rgba(255, 255, 255, 0.4);
  font-size: 20rpx;
  background-color: rgba(255, 255, 255, 0.06);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.rank-points {
  font-size: 32rpx;
  font-weight: bold;
  min-width: 80rpx;
  text-align: right;
}

.rank-points.positive {
  color: #f1c40f;
}

.rank-points.negative {
  color: #e74c3c;
}

.empty-tip {
  display: flex;
  justify-content: center;
  padding: 60rpx;
  color: rgba(255, 255, 255, 0.3);
  font-size: 28rpx;
}
