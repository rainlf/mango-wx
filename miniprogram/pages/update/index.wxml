<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="back">
      <text class="back-text">← 返回</text>
    </view>
  </view>
  
  <view class="update-box">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl || user.avatar}}" class="avatar" src="{{avatarUrl || user.avatar}}"></image>
      <view wx:else class="avatar avatar-placeholder"></view>
    </button>
    <text class="avatar-tip">点击更换头像</text>
    
    <view class="input-box">
      <input
        type="nickname"
        class="nickname-input"
        placeholder="请输入昵称"
        bindinput="onNicknameInput"
        value="{{nickname}}"
      />
    </view>
    
    <button class="save-btn" bindtap="save">保存</button>
  </view>
</view>
