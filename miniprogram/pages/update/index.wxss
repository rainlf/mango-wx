.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #2c3e50;
}

.header {
  padding: 60rpx 30rpx 20rpx;
}

.back-btn {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
}

.back-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.update-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 10%;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-tip {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  margin-top: 16rpx;
  margin-bottom: 60rpx;
}

.input-box {
  width: 100%;
  margin-bottom: 60rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  color: #fff;
  font-size: 30rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #3498db;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
}

.save-btn::after {
  border: none;
}
