page {
  min-height: 100vh;
  background: transparent;
}

.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.page-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.page-bg-mask {
  position: absolute;
  inset: 0;
  background: rgba(20, 33, 61, 0.38);
}

.container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.header {
  padding: 60rpx 30rpx 20rpx;
}

.back-btn {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
}

.back-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.update-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 10%;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  background-color: rgba(255, 255, 255, 0.12);
}

.avatar-tip {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  margin-top: 16rpx;
  margin-bottom: 60rpx;
}

.input-box {
  width: 100%;
  margin-bottom: 60rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.36);
  box-shadow: 0 8rpx 22rpx rgba(16, 31, 54, 0.12);
  overflow: hidden;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  color: #fff;
  font-size: 30rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.nickname-placeholder {
  color: rgba(255, 255, 255, 0.72);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #3498db;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
}

.save-btn::after {
  border: none;
}
