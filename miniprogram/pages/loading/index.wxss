.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.page-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.page-bg-mask {
  position: absolute;
  inset: 0;
  background: rgba(20, 33, 61, 0.38);
}

.container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 48rpx;
}

.brand-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 42rpx;
  padding: 32rpx 44rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.14);
  backdrop-filter: blur(10rpx);
  animation: breathe 3.2s ease-in-out infinite;
}

.brand-title {
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.24);
}

.brand-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
}

@keyframes breathe {
  0%,
  100% {
    transform: translateY(0) scale(1);
    opacity: 0.94;
  }
  50% {
    transform: translateY(-6rpx) scale(1.015);
    opacity: 1;
  }
}

.progress-bar {
  width: 60%;
  max-width: 420rpx;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.24);
  border-radius: 4rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.16);
}

.progress-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #3498db, #2ecc71);
  border-radius: 4rpx;
  transition: width 0.3s ease;
  background-size: 40rpx 40rpx;
  background-image: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.15) 25%,
    transparent 25%,
    transparent 50%,
    rgba(255, 255, 255, 0.15) 50%,
    rgba(255, 255, 255, 0.15) 75%,
    transparent 75%,
    transparent
  );
  animation: move 1s linear infinite;
}

@keyframes move {
  0% {
    background-position: 0 0;
  }
  100% {
    background-position: 40rpx 0;
  }
}

.loading-text {
  margin-top: 30rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}
