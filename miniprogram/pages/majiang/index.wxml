<block>
  <image class="page-bg" src="/images/background.png" mode="aspectFill" />
  <view class="page-bg-mask"></view>
  <scroll-view
    class="page-scroll"
    scroll-y
    enhanced
    refresher-enabled
    refresher-default-style="none"
    refresher-triggered="{{isPageRefreshing}}"
    bindrefresherrefresh="onPageRefresh"
  >
  <view class="container">
    <view wx:if="{{isPageRefreshing}}" class="pull-refresh-tip">
      <view class="pull-refresh-tip__spinner"></view>
      <text class="pull-refresh-tip__text">正在刷新用户信息与排行</text>
    </view>

    <view class="top-container">
      <!-- userinfo 组件 -->
      <userinfo
        class="user-info"
        username="{{user.username}}"
        points="{{user.points}}"
        avatar="{{user.avatar}}"
        totalGames="{{user.totalGames}}"
        winCount="{{user.winCount}}"
        winRate="{{user.winRate}}"
      />

      <block wx:if="{{showUserRank}}">
        <rank
          class="content-panel"
          listData="{{rankList}}"
          bind:load="handleRankListLoad"
          bind:clickUserAvatar="handleClickUserAvatar"
        />
      </block>

      <block wx:if="{{showGameLog}}">
        <majiang-log
          class="content-panel"
          id="game-log-component"
          listData="{{gameList}}"
          hasMoreData="{{hasMoreData}}"
          bind:load="handleGameListLoad"
          bind:refreshData="refreshData"
          bind:loadMore="handleLoadMore"
        />
      </block>

      <block wx:if="{{showUserGameLog}}">
        <majiang-log
          class="content-panel"
          id="user-game-log-component"
          listData="{{userGameList}}"
          hasMoreData="{{hasMoreData}}"
          bind:load="handleGameListLoad"
          bind:loadMore="handleLoadMore"
        />
      </block>
    </view>

    <view class="bottom-container">
      <view
        class="nav-btn nav-btn-rank {{showUserRank ? 'nav-btn-active nav-btn-rank-active' : ''}}"
        catch:tap="openUserRank"
      >
        <text class="nav-btn-title">玩家排行</text>
      </view>

      <view
        class="nav-btn nav-btn-history {{(showGameLog || showUserGameLog) ? 'nav-btn-active nav-btn-history-active' : ''}}"
        catch:tap="openGameLog"
      >
        <text class="nav-btn-title">游戏历史</text>
      </view>

      <view
        class="nav-btn nav-btn-record {{showDrawer ? 'nav-btn-active nav-btn-record-active' : ''}}"
        catch:tap="openRecordGame"
      >
        <text class="nav-btn-title">记录游戏</text>
      </view>
    </view>

    <view class="game-container">
      <majiang-game showDrawer="{{showDrawer}}" bind:refreshData="refreshData" bind:closeDrawer="handleCloseDrawer" />
    </view>
  </view>
  </scroll-view>
</block>
