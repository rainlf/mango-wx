<block>
  <image class="page-bg" src="/images/background.png" mode="aspectFill" />
  <view class="page-bg-mask"></view>
  <scroll-view
    class="page-scroll"
    scroll-y
    enhanced
    refresher-enabled
    refresher-default-style="none"
    refresher-triggered="{{isPageRefreshing}}"
    bindrefresherrefresh="onPageRefresh"
  >
  <view class="container">
    <view wx:if="{{isPageRefreshing}}" class="pull-refresh-tip">
      <view class="pull-refresh-tip__spinner"></view>
      <text class="pull-refresh-tip__text">正在刷新用户信息与排行</text>
    </view>

    <view class="top-container">
      <!-- userinfo 组件 -->
      <userinfo
        class="user-info"
        username="{{user.username}}"
        points="{{user.points}}"
        avatar="{{user.avatar}}"
        totalGames="{{user.totalGames}}"
        winCount="{{user.winCount}}"
        winRate="{{user.winRate}}"
        bind:settingsclick="openProfileEditor"
      />

      <block wx:if="{{showUserRank}}">
        <rank
          class="content-panel"
          listData="{{rankList}}"
          bind:load="handleRankListLoad"
          bind:clickUserAvatar="handleClickUserAvatar"
        />
      </block>

      <block wx:if="{{showGameLog}}">
        <majiang-log
          class="content-panel"
          id="game-log-component"
          listData="{{gameList}}"
          hasMoreData="{{hasMoreData}}"
          bind:load="handleGameListLoad"
          bind:refreshData="refreshData"
          bind:loadMore="handleLoadMore"
        />
      </block>

      <block wx:if="{{showUserGameLog}}">
        <majiang-log
          class="content-panel"
          id="user-game-log-component"
          listData="{{userGameList}}"
          hasMoreData="{{hasMoreData}}"
          bind:load="handleGameListLoad"
          bind:loadMore="handleLoadMore"
        />
      </block>
    </view>

    <view class="bottom-container">
      <view
        class="nav-btn nav-btn-rank {{showUserRank ? 'nav-btn-active nav-btn-rank-active' : ''}}"
        catch:tap="openUserRank"
      >
        <text class="nav-btn-title">玩家排行</text>
      </view>

      <view
        class="nav-btn nav-btn-history {{(showGameLog || showUserGameLog) ? 'nav-btn-active nav-btn-history-active' : ''}}"
        catch:tap="openGameLog"
      >
        <text class="nav-btn-title">游戏历史</text>
      </view>

      <view
        class="nav-btn nav-btn-record {{showDrawer ? 'nav-btn-active nav-btn-record-active' : ''}}"
        catch:tap="openRecordGame"
      >
        <text class="nav-btn-title">记录游戏</text>
      </view>
    </view>

    <view class="game-container">
      <majiang-game showDrawer="{{showDrawer}}" bind:refreshData="refreshData" bind:closeDrawer="handleCloseDrawer" />
    </view>

    <view wx:if="{{showProfileDrawer}}" class="profile-drawer-container">
      <view class="profile-drawer-mask" bindtap="closeProfileEditor"></view>
      <view class="profile-drawer">
        <view class="profile-drawer-handle"></view>
        <view class="profile-drawer-header">
          <text class="profile-drawer-title">修改资料</text>
          <view class="profile-drawer-close" bindtap="closeProfileEditor">关闭</view>
        </view>

        <view class="profile-drawer-body">
          <button class="profile-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onProfileChooseAvatar">
            <image
              wx:if="{{profileAvatarUrl || user.avatar}}"
              class="profile-avatar"
              src="{{profileAvatarUrl || user.avatar}}"
              mode="aspectFill"
            ></image>
            <view wx:else class="profile-avatar profile-avatar-placeholder">+</view>
          </button>
          <text class="profile-avatar-tip">点击更换头像</text>

          <view class="profile-input-box">
            <input
              type="nickname"
              class="profile-nickname-input"
              placeholder="请输入昵称"
              placeholder-class="profile-nickname-placeholder"
              bindinput="onProfileNicknameInput"
              value="{{profileNickname}}"
            />
          </view>
        </view>

        <view class="profile-drawer-footer">
          <view class="profile-footer-btn profile-footer-btn-cancel" bindtap="closeProfileEditor">取消</view>
          <view class="profile-footer-btn profile-footer-btn-confirm" bindtap="saveProfile">
            {{isProfileSaving ? '保存中...' : '保存'}}
          </view>
        </view>
      </view>
    </view>
  </view>
  </scroll-view>
</block>
