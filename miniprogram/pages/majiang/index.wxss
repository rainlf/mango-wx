/* 页面整体布局 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background-color: #f5f5f5;
}

.container {
  flex: 1;
  padding: 75px 0 120px 0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.top-container {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  min-height: 0;
}

.bottom-container {
  padding: 20rpx;
  padding-bottom: 60rpx;
  width: 100%;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  position: absolute;
  bottom: 0;
  left: 0;
  background-color: #fff;
}

.rank {
  flex: 1;
}

.start-btn {
  flex: 1;
  margin-left: 20rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb600 100%);
  box-shadow: 0 6rpx 18rpx rgba(255, 215, 0, 0.3);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.history-btn {
  flex: 1;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #0066cc 100%);
  box-shadow: 0 6rpx 18rpx rgba(74, 144, 226, 0.3);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}
