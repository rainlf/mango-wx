/* 页面整体布局 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: transparent;
  overflow: hidden;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

.page-bg-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.08) 0%,
    rgba(255, 255, 255, 0.14) 45%,
    rgba(255, 255, 255, 0.22) 100%
  );
}

.page-scroll {
  height: 100vh;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.container {
  height: 100vh;
  padding: 75px 0 0 0;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
  min-height: 0;
  box-sizing: border-box;
  overflow: hidden;
}

.pull-refresh-tip {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 12rpx);
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 251, 242, 0.98) 0%, rgba(239, 248, 255, 0.98) 100%);
  border: 1rpx solid rgba(126, 159, 209, 0.18);
  box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.12);
  backdrop-filter: blur(8rpx);
}

.pull-refresh-tip__spinner {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(74, 144, 226, 0.18);
  border-top-color: #ffb300;
  border-right-color: #4a90e2;
  box-sizing: border-box;
  animation: pull-refresh-spin 0.9s linear infinite;
  flex-shrink: 0;
}

.pull-refresh-tip__text {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #516882;
  white-space: nowrap;
}

@keyframes pull-refresh-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.top-container {
  width: 100%;
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: flex-start;
  min-height: 0;
  overflow: hidden;
  padding-bottom: 112rpx;
  box-sizing: border-box;
}

.bottom-container {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 0;
  width: auto;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 10rpx 18rpx 8rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  z-index: 2;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(248, 251, 255, 0.96) 100%);
  border: 1rpx solid rgba(126, 159, 209, 0.16);
  box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.1);
  backdrop-filter: blur(8rpx);
}

.content-panel {
  flex: 1;
  min-height: 0;
  display: block;
  overflow: hidden;
}

.nav-btn {
  flex: 1;
  min-height: 72rpx;
  padding: 10rpx 14rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 999rpx;
  border: 1rpx solid rgba(126, 159, 209, 0.16);
  box-shadow: 0 4rpx 12rpx rgba(86, 115, 156, 0.06);
  box-sizing: border-box;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.nav-btn-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #31445c;
}

.nav-btn-rank {
  background: linear-gradient(180deg, #f2fbff 0%, #e5f6ff 100%);
  border-color: rgba(0, 162, 194, 0.14);
}

.nav-btn-rank .nav-btn-title {
  color: #4a8192;
}

.nav-btn-history {
  background: linear-gradient(180deg, #f7f4ff 0%, #efebff 100%);
  border-color: rgba(132, 118, 230, 0.14);
}

.nav-btn-history .nav-btn-title {
  color: #6c63a8;
}

.nav-btn-active {
  transform: translateY(-1rpx);
}

.nav-btn-rank-active {
  background: linear-gradient(180deg, #eefaff 0%, #dff4ff 100%);
  border-color: rgba(0, 162, 194, 0.22);
  box-shadow: 0 8rpx 20rpx rgba(0, 162, 194, 0.12);
}

.nav-btn-rank-active .nav-btn-title {
  color: #0f6e82;
}

.nav-btn-history-active {
  background: linear-gradient(180deg, #f5f3ff 0%, #ece8ff 100%);
  border-color: rgba(132, 118, 230, 0.2);
  box-shadow: 0 8rpx 20rpx rgba(132, 118, 230, 0.12);
}

.nav-btn-history-active .nav-btn-title {
  color: #5a4db0;
}

.nav-btn-record {
  background: linear-gradient(135deg, #ffd86d 0%, #ffb300 100%);
  border-color: rgba(214, 144, 0, 0.2);
  box-shadow: 0 8rpx 20rpx rgba(255, 183, 77, 0.2);
}

.nav-btn-record .nav-btn-title {
  color: #fff;
}

.nav-btn-record-active {
  box-shadow: 0 10rpx 24rpx rgba(255, 183, 77, 0.28);
}
