/* 页面整体布局 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: transparent;
  overflow: hidden;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

.page-bg-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.08) 0%,
    rgba(255, 255, 255, 0.14) 45%,
    rgba(255, 255, 255, 0.22) 100%
  );
}

.page-scroll {
  height: 100vh;
  position: relative;
  z-index: 1;
}

.container {
  padding: 75px 0 120px 0;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
  min-height: 100vh;
  box-sizing: border-box;
}

.pull-refresh-tip {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 12rpx);
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 251, 242, 0.98) 0%, rgba(239, 248, 255, 0.98) 100%);
  border: 1rpx solid rgba(126, 159, 209, 0.18);
  box-shadow: 0 8rpx 22rpx rgba(62, 91, 135, 0.12);
  backdrop-filter: blur(8rpx);
}

.pull-refresh-tip__spinner {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(74, 144, 226, 0.18);
  border-top-color: #ffb300;
  border-right-color: #4a90e2;
  box-sizing: border-box;
  animation: pull-refresh-spin 0.9s linear infinite;
  flex-shrink: 0;
}

.pull-refresh-tip__text {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #516882;
  white-space: nowrap;
}

@keyframes pull-refresh-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.top-container {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  min-height: 0;
}

.bottom-container {
  padding: 20rpx 24rpx calc(8rpx + env(safe-area-inset-bottom));
  width: 100%;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 20rpx;
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  box-sizing: border-box;
  background-color: rgba(255, 255, 255, 0.92);
}

.rank {
  flex: 1;
}

.start-btn {
  flex: 1;
  background: linear-gradient(135deg, #ffd700 0%, #ffb600 100%);
  box-shadow: 0 6rpx 18rpx rgba(255, 215, 0, 0.3);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.history-btn {
  flex: 1;
  background: linear-gradient(135deg, #4a90e2 0%, #0066cc 100%);
  box-shadow: 0 6rpx 18rpx rgba(74, 144, 226, 0.3);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.start-btn::after,
.history-btn::after {
  border: none;
}
