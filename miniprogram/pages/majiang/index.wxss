page {
  background: transparent;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

.page-bg-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  background: linear-gradient(
    180deg,
    rgba(8, 15, 28, 0.42) 0%,
    rgba(8, 15, 28, 0.18) 28%,
    rgba(8, 15, 28, 0.12) 58%,
    rgba(8, 15, 28, 0.32) 100%
  );
}

.page-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: transparent;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
  padding-bottom: 120rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  height: 100rpx;
  background-color: rgba(18, 29, 43, 0.8);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  z-index: 100;
  backdrop-filter: blur(12rpx);
}

.bar-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.bar-btn.active {
  color: #7fd3ff;
}

.bar-btn.record-btn {
  color: #7df0b2;
  font-weight: bold;
}
