{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "target": "ES2020",
    "module": "CommonJS",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "typeRoots": [
      "./typings"
    ]
  },
  "include": [
    "miniprogram/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
